# Supabase Configuration
# Get these from https://supabase.com
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# PayPal Configuration
# Get these from https://developer.paypal.com
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id

# OpenRouter AI Configuration (for ClawBot)
# Get this from https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Application URLs
PUBLIC_APP_URL=https://clawmaster.io

# Node Environment
NODE_ENV=production
